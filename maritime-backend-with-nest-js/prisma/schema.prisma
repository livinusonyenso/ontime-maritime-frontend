generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  buyer
  seller
  admin
  executive
  expert
}

enum ListingCategory {
  cargo
  ship
  spare_part
  service
}

enum ListingStatus {
  draft
  pending
  executive_review
  active
  sold
  archived
}

enum TransactionType {
  buy_now
  auction
}

enum PayoutStatus {
  pending
  completed
  failed
}

enum DocumentType {
  invoice
  bill_of_lading
  packing_list
  delivery_order
  charterparty
  survey_report
  insurance_certificate
}

enum KycStatus {
  pending
  approved
  rejected
}

enum AuctionStatus {
  active
  ended
  cancelled
}

enum ExecutiveCornerStatus {
  pending
  approved
  rejected
  auto_released
}

enum NotificationType {
  sms
  email
  push
}

enum NotificationStatus {
  sent
  failed
  pending
}

model User {
  id                  String    @id @default(uuid())
  role                UserRole  @default(buyer)
  email               String    @unique
  phone               String    @unique
  password_hash       String
  is_phone_verified   Boolean   @default(false)
  is_email_verified   Boolean   @default(false)
  subscription_status String    @default("free") // "free" or "paid"
  subscription_expiry DateTime?
  first_name          String?
  last_name           String?
  created_at          DateTime  @default(now())
  updated_at          DateTime  @updatedAt

  listings        Listing[]
  purchases       Transaction[]     @relation("BuyerTransactions")
  sales           Transaction[]     @relation("SellerTransactions")
  kyc             Kyc[]
  won_auctions    Auction[]         @relation("AuctionWinner")
  auction_bids    AuctionBid[]
  decisions       ExecutiveCorner[] @relation("ExecutiveDecisions")
  staff_accounts    StaffAccount[]

  @@index([email])
  @@index([phone])
  @@index([subscription_status])
  @@map("users")
}

model Listing {
  id               String          @id @default(uuid())
  seller_id        String
  category         ListingCategory
  title            String
  description      String          @db.Text
  price_usd        Decimal         @db.Decimal(18, 2)
  origin_port      String
  destination_port String
  container_number String?
  eta              DateTime
  photos           Json? // String[]
  certificates     Json? // String[]
  is_perishable    Boolean         @default(false)
  is_dangerous     Boolean         @default(false)
  is_high_value    Boolean         @default(false)
  status           ListingStatus   @default(draft)
  created_at       DateTime        @default(now())
  updated_at       DateTime        @updatedAt

  seller           User              @relation(fields: [seller_id], references: [id], onDelete: Cascade)
  transactions     Transaction[]
  auctions         Auction[]
  documents        Document[]
  executive_corner ExecutiveCorner[]
  insurance_policies InsurancePolicy[]

  @@index([seller_id])
  @@index([status])
  @@index([is_high_value])
  @@index([created_at])
  @@map("listings")
}

model Transaction {
  id                String          @id @default(uuid())
  buyer_id          String
  seller_id         String
  listing_id        String
  amount            Decimal         @db.Decimal(18, 2)
  commission_amount Decimal         @db.Decimal(18, 2)
  payment_reference String?
  payout_status     PayoutStatus    @default(pending)
  transaction_type  TransactionType
  created_at        DateTime        @default(now())
  updated_at        DateTime        @updatedAt

  buyer     User       @relation("BuyerTransactions", fields: [buyer_id], references: [id], onDelete: Cascade)
  seller    User       @relation("SellerTransactions", fields: [seller_id], references: [id], onDelete: Cascade)
  listing   Listing    @relation(fields: [listing_id], references: [id], onDelete: Cascade)
  documents Document[]
  arbitration_cases ArbitrationCase[]

  @@index([buyer_id])
  @@index([seller_id])
  @@index([payout_status])
  @@index([created_at])
  @@map("transactions")
}

model Document {
  id             String       @id @default(uuid())
  type           DocumentType
  listing_id     String?
  transaction_id String?
  file_url       String
  qr_hash        String?
  is_revoked     Boolean      @default(false)
  created_at     DateTime     @default(now())

  listing     Listing?     @relation(fields: [listing_id], references: [id])
  transaction Transaction? @relation(fields: [transaction_id], references: [id])

  @@map("documents")
}

model Kyc {
  id              String    @id @default(uuid())
  user_id         String
  bvn             String?
  id_type         String? // "NIN", "passport", "voter_card", "drivers_license"
  id_number       String?
  id_document_url String?
  face_photo_url  String?
  status          KycStatus @default(pending)
  admin_comment   String?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  user User @relation(fields: [user_id], references: [id])

  @@map("kyc")
}

model Auction {
  id             String        @id @default(uuid())
  listing_id     String        @unique
  starting_price Decimal       @db.Decimal(18, 2)
  current_price  Decimal       @db.Decimal(18, 2)
  reserve_price  Decimal?      @db.Decimal(18, 2)
  status         AuctionStatus @default(active)
  start_time     DateTime
  end_time       DateTime
  winner_id      String?
  created_at     DateTime      @default(now())
  updated_at     DateTime      @updatedAt

  listing Listing      @relation(fields: [listing_id], references: [id], onDelete: Cascade)
  winner  User?        @relation("AuctionWinner", fields: [winner_id], references: [id], onDelete: SetNull)
  bids    AuctionBid[]

  @@index([status])
  @@index([end_time])
  @@index([winner_id])
  @@map("auctions")
}

model AuctionBid {
  id         String   @id @default(uuid())
  auction_id String
  bidder_id  String
  amount     Decimal  @db.Decimal(18, 2)
  created_at DateTime @default(now())

  auction Auction @relation(fields: [auction_id], references: [id])
  bidder  User    @relation(fields: [bidder_id], references: [id])

  @@map("auction_bids")
}

model ExecutiveCorner {
  id               String                @id @default(uuid())
  listing_id       String                @unique
  submitted_at     DateTime
  deadline_at      DateTime
  status           ExecutiveCornerStatus @default(pending)
  decided_by       String?
  decided_at       DateTime?
  decision_comment String?
  logs             Json?
  created_at       DateTime              @default(now())
  updated_at       DateTime              @updatedAt

  listing   Listing @relation(fields: [listing_id], references: [id], onDelete: Cascade)
  decidedBy User?   @relation("ExecutiveDecisions", fields: [decided_by], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([deadline_at])
  @@map("executive_corner")
}

model TrackingLog {
  id               String   @id @default(uuid())
  container_number String
  vessel_imo       String?
  lat              Decimal  @db.Decimal(10, 6)
  lng              Decimal  @db.Decimal(10, 6)
  speed            Decimal? @db.Decimal(5, 2)
  heading          String?
  timestamp        DateTime
  created_at       DateTime @default(now())

  @@map("tracking_logs")
}

model Notification {
  id         String             @id @default(uuid())
  user_id    String
  type       NotificationType
  title      String
  body       String             @db.Text
  status     NotificationStatus @default(pending)
  created_at DateTime           @default(now())

  @@map("notifications")
}

model AuditLog {
  id         String   @id @default(uuid())
  actor_id   String?
  action     String
  module     String
  details    Json?
  ip_address String
  timestamp  DateTime @default(now())

  @@map("audit_logs")
}

model FraudFlag {
  id        String   @id @default(uuid())
  user_id   String
  trigger   String
  severity  Int      @default(1) // 1-10 scale
  metadata  Json?
  created_at DateTime @default(now())

  @@index([user_id])
  @@index([severity])
  @@index([created_at])
  @@map("fraud_flags")
}

model Rating {
  id        String   @id @default(uuid())
  user_id   String   // The user being rated
  rater_id  String   // The user giving the rating
  score     Int      // 1-5
  comment   String?  @db.Text
  created_at DateTime @default(now())

  @@index([user_id])
  @@index([rater_id])
  @@index([created_at])
  @@map("ratings")
}

model InsuranceProvider {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  phone     String?
  website   String?
  is_verified Boolean @default(false)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  policies InsurancePolicy[]

  @@map("insurance_providers")
}

model InsurancePolicy {
  id           String   @id @default(uuid())
  buyer_id     String
  listing_id   String?
  provider_id  String
  policy_number String @unique
  policy_pdf_url String
  status       String   @default("active") // "active", "expired"
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  provider InsuranceProvider @relation(fields: [provider_id], references: [id])
  listing  Listing?           @relation(fields: [listing_id], references: [id])

  @@map("insurance_policies")
}

model ArbitrationCase {
  id              String   @id @default(uuid())
  transaction_id  String
  complainant_id  String
  defendant_id    String
  issue_summary   String   @db.Text
  evidence_urls   Json?    // String[]
  status          String   @default("open") // "open", "resolved", "escalated"
  resolution      String?  @db.Text
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  transaction Transaction @relation(fields: [transaction_id], references: [id])

  @@map("arbitration_cases")
}

model ApiUsageLog {
  id           String   @id @default(uuid())
  api_name     String
  request_url  String
  cost         Decimal? @db.Decimal(10, 4)
  returned     Boolean  @default(true)
  timestamp    DateTime @default(now())

  @@map("api_usage_logs")
}

model StaffAccount {
  id           String   @id @default(uuid())
  user_id      String
  account_type String   @default("hidden") // "hidden", "special"
  restrictions String?  @db.Text
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  user User @relation(fields: [user_id], references: [id])

  @@map("staff_accounts")
}

model Subscription {
  id             String   @id @default(uuid())
  user_id        String   @unique
  tier           String   @default("free") // "free", "basic", "premium"
  amount         Decimal? @db.Decimal(10, 2)
  currency       String   @default("NGN")
  is_active      Boolean  @default(false)
  started_at     DateTime?
  expires_at     DateTime?
  renewal_date   DateTime?
  payment_ref    String?
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  @@map("subscriptions")
}

model LoginAttempt {
  id        String   @id @default(uuid())
  email     String
  success   Boolean
  ip_address String
  timestamp DateTime @default(now())

  @@index([email])
  @@index([success])
  @@index([timestamp])
  @@map("login_attempts")
}

model OtpToken {
  id        String   @id @default(uuid())
  user_id   String
  email     String
  otp_code  String
  purpose   String   // "signup", "login", "password_reset"
  is_used   Boolean  @default(false)
  expires_at DateTime
  created_at DateTime @default(now())

  @@index([email])
  @@index([expires_at])
  @@map("otp_tokens")
}
