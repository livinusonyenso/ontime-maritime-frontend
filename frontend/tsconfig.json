{
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "target": "ES6",
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    // <CHANGE> Updated JSX to react-jsx for Vite
    "jsx": "react-jsx",
    "incremental": true,
    // <CHANGE> Removed Next.js plugin
    "plugins": [],
    "paths": {
      // <CHANGE> Updated path alias to match vite.config.ts
      "@/*": ["./src/*"]
    },
    // <CHANGE> Added Vite client types
    "types": ["vite/client"]
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
