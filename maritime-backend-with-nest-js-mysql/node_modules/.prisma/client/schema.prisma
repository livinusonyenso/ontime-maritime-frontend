generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  buyer
  seller
  admin
  executive
  expert
}

enum ListingCategory {
  cargo
  ship
  spare_part
  service
}

enum ListingStatus {
  draft
  pending
  executive_review
  active
  sold
  archived
}

enum TransactionType {
  buy_now
  auction
}

enum PayoutStatus {
  pending
  completed
  failed
}

enum DocumentType {
  invoice
  bill_of_lading
  packing_list
  delivery_order
  charterparty
  survey_report
  insurance_certificate
}

enum KycStatus {
  pending
  approved
  rejected
}

enum AuctionStatus {
  active
  ended
  cancelled
}

enum ExecutiveCornerStatus {
  pending
  approved
  rejected
  auto_released
}

enum NotificationType {
  sms
  email
  push
}

enum NotificationStatus {
  sent
  failed
  pending
}

model User {
  id                  String    @id @default(uuid()) @db.VarChar(36)
  role                UserRole  @default(buyer)
  email               String    @unique @db.VarChar(255)
  phone               String    @unique @db.VarChar(20)
  password_hash       String    @db.VarChar(255)
  is_phone_verified   Boolean   @default(false)
  is_email_verified   Boolean   @default(false)
  subscription_status String    @default("free") @db.VarChar(50)
  subscription_expiry DateTime?
  first_name          String?   @db.VarChar(100)
  last_name           String?   @db.VarChar(100)
  created_at          DateTime  @default(now())
  updated_at          DateTime  @updatedAt

  listings        Listing[]
  purchases       Transaction[]     @relation("BuyerTransactions")
  sales           Transaction[]     @relation("SellerTransactions")
  kyc             Kyc[]
  won_auctions    Auction[]         @relation("AuctionWinner")
  auction_bids    AuctionBid[]
  decisions       ExecutiveCorner[] @relation("ExecutiveDecisions")
  staff_accounts  StaffAccount[]

  @@index([email])
  @@index([phone])
  @@index([subscription_status])
  @@map("users")
}

model Listing {
  id               String          @id @default(uuid()) @db.VarChar(36)
  seller_id        String          @db.VarChar(36)
  category         ListingCategory
  title            String          @db.VarChar(255)
  description      String          @db.Text
  price_usd        Decimal         @db.Decimal(18, 2)
  origin_port      String          @db.VarChar(100)
  destination_port String          @db.VarChar(100)
  container_number String?         @db.VarChar(50)
  eta              DateTime
  photos           Json?
  certificates     Json?
  is_perishable    Boolean         @default(false)
  is_dangerous     Boolean         @default(false)
  is_high_value    Boolean         @default(false)
  status           ListingStatus   @default(draft)
  created_at       DateTime        @default(now())
  updated_at       DateTime        @updatedAt

  seller             User              @relation(fields: [seller_id], references: [id], onDelete: Cascade)
  transactions       Transaction[]
  auctions           Auction[]
  documents          Document[]
  executive_corner   ExecutiveCorner[]
  insurance_policies InsurancePolicy[]

  @@index([seller_id])
  @@index([status])
  @@index([is_high_value])
  @@index([created_at])
  @@map("listings")
}

model Transaction {
  id                String          @id @default(uuid()) @db.VarChar(36)
  buyer_id          String          @db.VarChar(36)
  seller_id         String          @db.VarChar(36)
  listing_id        String          @db.VarChar(36)
  amount            Decimal         @db.Decimal(18, 2)
  commission_amount Decimal         @db.Decimal(18, 2)
  payment_reference String?         @db.VarChar(255)
  payout_status     PayoutStatus    @default(pending)
  transaction_type  TransactionType
  created_at        DateTime        @default(now())
  updated_at        DateTime        @updatedAt

  buyer             User              @relation("BuyerTransactions", fields: [buyer_id], references: [id], onDelete: Cascade)
  seller            User              @relation("SellerTransactions", fields: [seller_id], references: [id], onDelete: Cascade)
  listing           Listing           @relation(fields: [listing_id], references: [id], onDelete: Cascade)
  documents         Document[]
  arbitration_cases ArbitrationCase[]

  @@index([buyer_id])
  @@index([seller_id])
  @@index([payout_status])
  @@index([created_at])
  @@map("transactions")
}

model Document {
  id             String       @id @default(uuid()) @db.VarChar(36)
  type           DocumentType
  listing_id     String?      @db.VarChar(36)
  transaction_id String?      @db.VarChar(36)
  file_url       String       @db.VarChar(500)
  qr_hash        String?      @db.VarChar(255)
  is_revoked     Boolean      @default(false)
  created_at     DateTime     @default(now())

  listing     Listing?     @relation(fields: [listing_id], references: [id])
  transaction Transaction? @relation(fields: [transaction_id], references: [id])

  @@map("documents")
}

model Kyc {
  id              String    @id @default(uuid()) @db.VarChar(36)
  user_id         String    @db.VarChar(36)
  bvn             String?   @db.VarChar(20)
  id_type         String?   @db.VarChar(50)
  id_number       String?   @db.VarChar(50)
  id_document_url String?   @db.VarChar(500)
  face_photo_url  String?   @db.VarChar(500)
  status          KycStatus @default(pending)
  admin_comment   String?   @db.Text
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  user User @relation(fields: [user_id], references: [id])

  @@map("kyc")
}

model Auction {
  id             String        @id @default(uuid()) @db.VarChar(36)
  listing_id     String        @unique @db.VarChar(36)
  starting_price Decimal       @db.Decimal(18, 2)
  current_price  Decimal       @db.Decimal(18, 2)
  reserve_price  Decimal?      @db.Decimal(18, 2)
  status         AuctionStatus @default(active)
  start_time     DateTime
  end_time       DateTime
  winner_id      String?       @db.VarChar(36)
  created_at     DateTime      @default(now())
  updated_at     DateTime      @updatedAt

  listing Listing      @relation(fields: [listing_id], references: [id], onDelete: Cascade)
  winner  User?        @relation("AuctionWinner", fields: [winner_id], references: [id], onDelete: SetNull)
  bids    AuctionBid[]

  @@index([status])
  @@index([end_time])
  @@index([winner_id])
  @@map("auctions")
}

model AuctionBid {
  id         String   @id @default(uuid()) @db.VarChar(36)
  auction_id String   @db.VarChar(36)
  bidder_id  String   @db.VarChar(36)
  amount     Decimal  @db.Decimal(18, 2)
  created_at DateTime @default(now())

  auction Auction @relation(fields: [auction_id], references: [id])
  bidder  User    @relation(fields: [bidder_id], references: [id])

  @@map("auction_bids")
}

model ExecutiveCorner {
  id               String                @id @default(uuid()) @db.VarChar(36)
  listing_id       String                @unique @db.VarChar(36)
  submitted_at     DateTime
  deadline_at      DateTime
  status           ExecutiveCornerStatus @default(pending)
  decided_by       String?               @db.VarChar(36)
  decided_at       DateTime?
  decision_comment String?               @db.Text
  logs             Json?
  created_at       DateTime              @default(now())
  updated_at       DateTime              @updatedAt

  listing   Listing @relation(fields: [listing_id], references: [id], onDelete: Cascade)
  decidedBy User?   @relation("ExecutiveDecisions", fields: [decided_by], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([deadline_at])
  @@map("executive_corner")
}

model TrackingLog {
  id               String   @id @default(uuid()) @db.VarChar(36)
  container_number String   @db.VarChar(50)
  vessel_imo       String?  @db.VarChar(20)
  lat              Decimal  @db.Decimal(10, 6)
  lng              Decimal  @db.Decimal(10, 6)
  speed            Decimal? @db.Decimal(5, 2)
  heading          String?  @db.VarChar(10)
  timestamp        DateTime
  created_at       DateTime @default(now())

  @@index([container_number])
  @@index([timestamp])
  @@map("tracking_logs")
}

model Notification {
  id         String             @id @default(uuid()) @db.VarChar(36)
  user_id    String             @db.VarChar(36)
  type       NotificationType
  title      String             @db.VarChar(255)
  body       String             @db.Text
  status     NotificationStatus @default(pending)
  created_at DateTime           @default(now())

  @@index([user_id])
  @@index([status])
  @@map("notifications")
}

model AuditLog {
  id         String   @id @default(uuid()) @db.VarChar(36)
  actor_id   String?  @db.VarChar(36)
  action     String   @db.VarChar(100)
  module     String   @db.VarChar(50)
  details    Json?
  ip_address String   @db.VarChar(45)
  timestamp  DateTime @default(now())

  @@index([actor_id])
  @@index([module])
  @@index([timestamp])
  @@map("audit_logs")
}

model FraudFlag {
  id         String   @id @default(uuid()) @db.VarChar(36)
  user_id    String   @db.VarChar(36)
  trigger    String   @db.VarChar(255)
  severity   Int      @default(1)
  metadata   Json?
  created_at DateTime @default(now())

  @@index([user_id])
  @@index([severity])
  @@index([created_at])
  @@map("fraud_flags")
}

model Rating {
  id         String   @id @default(uuid()) @db.VarChar(36)
  user_id    String   @db.VarChar(36)
  rater_id   String   @db.VarChar(36)
  score      Int
  comment    String?  @db.Text
  created_at DateTime @default(now())

  @@index([user_id])
  @@index([rater_id])
  @@index([created_at])
  @@map("ratings")
}

model InsuranceProvider {
  id          String   @id @default(uuid()) @db.VarChar(36)
  name        String   @db.VarChar(255)
  email       String   @unique @db.VarChar(255)
  phone       String?  @db.VarChar(20)
  website     String?  @db.VarChar(255)
  is_verified Boolean  @default(false)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  policies InsurancePolicy[]

  @@map("insurance_providers")
}

model InsurancePolicy {
  id             String   @id @default(uuid()) @db.VarChar(36)
  buyer_id       String   @db.VarChar(36)
  listing_id     String?  @db.VarChar(36)
  provider_id    String   @db.VarChar(36)
  policy_number  String   @unique @db.VarChar(100)
  policy_pdf_url String   @db.VarChar(500)
  status         String   @default("active") @db.VarChar(20)
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  provider InsuranceProvider @relation(fields: [provider_id], references: [id])
  listing  Listing?          @relation(fields: [listing_id], references: [id])

  @@index([buyer_id])
  @@index([provider_id])
  @@map("insurance_policies")
}

model ArbitrationCase {
  id             String   @id @default(uuid()) @db.VarChar(36)
  transaction_id String   @db.VarChar(36)
  complainant_id String   @db.VarChar(36)
  defendant_id   String   @db.VarChar(36)
  issue_summary  String   @db.Text
  evidence_urls  Json?
  status         String   @default("open") @db.VarChar(20)
  resolution     String?  @db.Text
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  transaction Transaction @relation(fields: [transaction_id], references: [id])

  @@index([transaction_id])
  @@index([status])
  @@map("arbitration_cases")
}

model ApiUsageLog {
  id          String   @id @default(uuid()) @db.VarChar(36)
  api_name    String   @db.VarChar(100)
  request_url String   @db.VarChar(500)
  cost        Decimal? @db.Decimal(10, 4)
  returned    Boolean  @default(true)
  timestamp   DateTime @default(now())

  @@index([api_name])
  @@index([timestamp])
  @@map("api_usage_logs")
}

model StaffAccount {
  id           String   @id @default(uuid()) @db.VarChar(36)
  user_id      String   @db.VarChar(36)
  account_type String   @default("hidden") @db.VarChar(20)
  restrictions String?  @db.Text
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  user User @relation(fields: [user_id], references: [id])

  @@index([user_id])
  @@map("staff_accounts")
}

model Subscription {
  id           String    @id @default(uuid()) @db.VarChar(36)
  user_id      String    @unique @db.VarChar(36)
  tier         String    @default("free") @db.VarChar(20)
  amount       Decimal?  @db.Decimal(10, 2)
  currency     String    @default("NGN") @db.VarChar(3)
  is_active    Boolean   @default(false)
  started_at   DateTime?
  expires_at   DateTime?
  renewal_date DateTime?
  payment_ref  String?   @db.VarChar(255)
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt

  @@map("subscriptions")
}

model LoginAttempt {
  id         String   @id @default(uuid()) @db.VarChar(36)
  email      String   @db.VarChar(255)
  success    Boolean
  ip_address String   @db.VarChar(45)
  timestamp  DateTime @default(now())

  @@index([email])
  @@index([success])
  @@index([timestamp])
  @@map("login_attempts")
}

model OtpToken {
  id         String   @id @default(uuid()) @db.VarChar(36)
  user_id    String   @db.VarChar(36)
  email      String   @db.VarChar(255)
  otp_code   String   @db.VarChar(10)
  purpose    String   @db.VarChar(20)
  is_used    Boolean  @default(false)
  expires_at DateTime
  created_at DateTime @default(now())

  @@index([email])
  @@index([expires_at])
  @@map("otp_tokens")
}

// Holds registration data while the user completes OTP verification.
// Deleted and converted to a real User record on successful verification.
model PendingRegistration {
  id            String   @id @default(uuid()) @db.VarChar(36)
  email         String   @unique @db.VarChar(255)
  phone         String   @unique @db.VarChar(20)
  password_hash String   @db.VarChar(255)
  role          String   @db.VarChar(20)
  otp_code      String   @db.VarChar(10)
  expires_at    DateTime
  created_at    DateTime @default(now())

  @@index([email])
  @@index([expires_at])
  @@map("pending_registrations")
}
